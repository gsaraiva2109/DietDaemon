# DietDaemon — environment configuration
# Copy to .env and fill in real values before starting.

# --- Messaging (required) ---
# Which messaging adapter to use: telegram, discord, matrix
MESSAGING_ADAPTER=telegram

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot API token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Matrix homeserver URL, bot user ID, and access token
MATRIX_HOMESERVER_URL=
MATRIX_USER_ID=
MATRIX_TOKEN=

# --- Parsing (required) ---
# Parser tier: 0=deterministic (no model), 1=embeddings, 2=LLM
PARSER_TIER=0

# --- Nutrition sources (required) ---
# Comma-separated, queried in order: openfoodfacts,taco
NUTRITION_SOURCE=openfoodfacts,taco

# USDA FoodData Central API key (optional; only needed if usda is in NUTRITION_SOURCE)
USDA_FDC_API_KEY=

# Path to the TACO dataset (required when 'taco' is in NUTRITION_SOURCE).
# Accepts .csv or .xlsx. Drop the file under ./data (mounted into the container).
TACO_DATA_PATH=/data/taco.csv

# --- Bulk food import (opt-in; off by default, no surprise startup traffic) ---
# Enables the scheduled bulk-import job. For a shared database, enable this on exactly one instance.
FOOD_IMPORT_ENABLED=false
# Comma-separated sources to bulk-import: usda,openfoodfacts,taco
FOOD_IMPORT_SOURCES=
# How often the scheduled bulk-import job re-syncs API-mode sources.
FOOD_IMPORT_INTERVAL=24h

# If set, USDA bulk import stream-parses this local file instead of calling the live API.
# Update local bulk files by preparing a replacement, then atomically renaming/redeploying it.
USDA_BULK_FILE=
# Comma-separated USDA dataType allowlist for bulk import.
USDA_BULK_DATA_TYPES='Foundation,SR Legacy'
# Hard cap on rows emitted by USDA bulk import (0 = unlimited).
USDA_BULK_MAX_ROWS=0

# If set, OpenFoodFacts bulk import stream-parses this local file instead of calling the live API.
OFF_BULK_FILE=
# Minimum popularity/unique_scans_n floor for OpenFoodFacts bulk import.
OFF_BULK_MIN_POPULARITY=0
# Hard cap on rows emitted by OpenFoodFacts bulk import (0 = unlimited).
OFF_BULK_MAX_ROWS=0

# Hard cap on rows emitted by TACO bulk import (0 = unlimited; TACO's dataset is already small).
TACO_BULK_MAX_ROWS=0

# --- Model ---
# Embedding adapter (Tier 1/2 food matching + /suggest candidate pool). Only
# "ollama" is supported — no other provider here offers embeddings.
EMBED_ADAPTER=ollama

# Completion adapter (Tier 2 parsing, /suggest ranking): ollama | anthropic | openai
# "openai" also covers any OpenAI-compatible endpoint (vLLM, Gemini's compat API,
# DeepSeek, etc.) via OPENAI_BASE_URL. Leave unset to auto-detect: OPENAI_API_KEY
# set -> openai, else ANTHROPIC_API_KEY set -> anthropic, else ollama (zero keys).
# Set explicitly only to override the auto-detected provider.
COMPLETION_ADAPTER=

# Ollama API base URL (must match the ollama service in docker-compose).
# Required when PARSER_TIER > 0, or when EMBED_ADAPTER/COMPLETION_ADAPTER=ollama.
OLLAMA_URL=http://ollama:11434

# Embedding model (Tier 1 matcher)
EMBED_MODEL=nomic-embed-text

# LLM model (Tier 2 parser, ollama completion)
LLM_MODEL=llama3.1

# HTTP timeout for model API calls (ollama/anthropic/openai)
MODEL_TIMEOUT=30s

# Pull required Ollama models at startup. Off by default: model downloads can be large.
OLLAMA_AUTO_PULL=false

# Anthropic completion adapter (required when COMPLETION_ADAPTER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI-compatible completion adapter (used when COMPLETION_ADAPTER=openai)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OCR-assisted nutrition-label capture (issue #87): ollama | anthropic | openai.
# Empty (default) disables the "Scan label" button entirely. Reuses the
# credentials/URL above for whichever provider you pick — this is a separate
# knob from COMPLETION_ADAPTER because not every chat model is vision-capable.
# Uploaded images are never persisted; extraction happens in-memory per request.
OCR_ADAPTER=

# Ollama vision model for OCR_ADAPTER=ollama (llama3.1 etc. have no vision support).
OLLAMA_VISION_MODEL=llava

# Minimum cosine similarity for an embedding match to be accepted (0..1)
EMBED_MATCH_THRESHOLD=0.80

# Minimum cosine similarity to auto-write an embedding match as a food alias (0..1)
ALIAS_WRITE_BACK_THRESHOLD=0.92

# --- Notifications ---
# Notifier adapter: ntfy, gotify, webhook
NOTIFIER=ntfy

# ntfy server URL (self-hosted or ntfy.sh)
NTFY_URL=

# ntfy topic to publish to
NTFY_TOPIC=

# ntfy access token (optional — only if your ntfy server restricts publishing)
NTFY_TOKEN=

# Gotify server URL (optional — only used when NOTIFIER=gotify)
GOTIFY_URL=
# Gotify app token (optional — only used when NOTIFIER=gotify)
GOTIFY_TOKEN=

# --- Timezone ---
# IANA timezone for daily rollup boundaries and scheduler ticks.
# Overridable per-user once multi-user lands.
DEFAULT_TIMEZONE=America/Sao_Paulo

# --- Database ---
# Path to the SQLite database file (ignored when using Postgres)
DB_PATH=/data/dietdaemon.db

# Database driver: sqlite (default) or postgres
DB_DRIVER=sqlite

# PostgreSQL connection URL. Set DB_DRIVER=postgres and use the Compose service
# hostname when enabling the postgres profile, for example:
# postgres://dietdaemon:<URL-encoded password>@postgres:5432/dietdaemon?sslmode=disable
DATABASE_URL=

# PostgreSQL Compose profile settings. Set POSTGRES_PASSWORD before enabling it.
POSTGRES_DB=dietdaemon
POSTGRES_USER=dietdaemon
POSTGRES_PASSWORD=

# --- Auth ---
# Who can register: invite (bootstrap first user then closed), open (anyone), oidc-only
AUTH_REGISTRATION_MODE=invite

# Enable multi-user mode. false hard-caps the instance at exactly one account
# regardless of AUTH_REGISTRATION_MODE; true lets AUTH_REGISTRATION_MODE
# govern further admission (open/invite/oidc-only). Accounts are always
# fully isolated — no shared targets/food library (see docs/ROADMAP.md).
MULTI_USER=false

# Static API bearer token for single-user mode (empty = no auth for localhost)
API_AUTH_TOKEN=

# Session idle timeout before re-auth required
SESSION_IDLE_TTL=168h

# Session absolute max lifetime
SESSION_ABSOLUTE_TTL=720h

# AES-256-GCM key for encrypting TOTP secrets at rest (32 bytes, hex or base64).
# TOTP 2FA is unavailable when unset.
TOTP_ENC_KEY=

# Label shown in the authenticator app (default: DietDaemon)
TOTP_ISSUER=DietDaemon

# --- Auth — OIDC ---

# Public base URL of the app, used to build OIDC redirect URIs.
# Required when OIDC_PROVIDERS is set.
# PUBLIC_BASE_URL=http://localhost:5173

# Comma-separated list of OIDC provider IDs (e.g. google,authentik,keycloak).
# Empty = OIDC disabled.
# OIDC_PROVIDERS=google,authentik

# Per-provider configuration. Replace <ID> with the upper-cased provider id.
# OIDC_<ID>_NAME=Google              # display name (defaults to title-cased id)
# OIDC_<ID>_ISSUER=https://accounts.google.com
# OIDC_<ID>_CLIENT_ID=your-client-id
# OIDC_<ID>_CLIENT_SECRET=your-client-secret
# OIDC_<ID>_SCOPES=openid,email,profile  # (default)

# Session absolute max lifetime when "remember me" is checked
SESSION_REMEMBER_TTL=2160h

# Set the Secure flag on cookies (disable for plain-http local dev)
COOKIE_SECURE=true

# Cookie domain override (empty = host-only)
COOKIE_DOMAIN=

# Comma-separated CIDRs (or bare IPs) whose X-Forwarded-For / X-Real-IP
# headers are trusted for resolving the client IP (rate limiting, lockout,
# audit logs). Defaults to loopback only. Set this to your reverse proxy's
# address when DietDaemon sits behind one — otherwise those headers are
# ignored and the proxy's own IP is used instead of the real client's.
TRUSTED_PROXIES=127.0.0.0/8,::1/128

# --- Auth — Email ---

# Email delivery provider: resend, ses, smtp, or none (dev/homelab — logs links to stdout).
# When set to "none", new users are auto-verified and no email is sent.
EMAIL_PROVIDER=none

# Verified sender address (required for resend, ses, and smtp).
# Must be a verified domain or identity in the chosen provider.
EMAIL_FROM=

# Resend API key (required when EMAIL_PROVIDER=resend).
# Get one at https://resend.com/api-keys.
RESEND_API_KEY=

# AWS SES region (default: provider chain). Only used when EMAIL_PROVIDER=ses.
SES_REGION=

# SMTP server host (required when EMAIL_PROVIDER=smtp).
SMTP_HOST=

# SMTP port (default 587). Only used when EMAIL_PROVIDER=smtp.
SMTP_PORT=587

# SMTP authentication credentials (optional; leave empty for unauthenticated relay).
SMTP_USERNAME=
SMTP_PASSWORD=

# Use TLS for SMTP connection (default true).
SMTP_TLS=true

# --- Feature flags ---
# Enable push notifications for target-miss nudges
ENABLE_NOTIFICATIONS=true

# Enable the optional dashboard UI (backend must still boot headless without it)
ENABLE_DASHBOARD=false

# Enable speech-to-text processing for audio messages
ENABLE_STT=false

# Whisper.cpp HTTP server URL (required when ENABLE_STT=true)
WHISPER_URL=http://whisper:8080

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info
