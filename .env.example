# DietDaemon — environment configuration
# Copy to .env and fill in real values before starting.

# --- Messaging (required) ---
# Which messaging adapter to use: telegram, discord, matrix
MESSAGING_ADAPTER=telegram

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot API token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Matrix homeserver URL, bot user ID, and access token
MATRIX_HOMESERVER_URL=
MATRIX_USER_ID=
MATRIX_TOKEN=

# --- Parsing (required) ---
# Parser tier: 0=deterministic (no model), 1=embeddings, 2=LLM
PARSER_TIER=0

# --- Nutrition sources (required) ---
# Comma-separated, queried in order: openfoodfacts,taco
NUTRITION_SOURCE=openfoodfacts,taco

# USDA FoodData Central API key (optional; only needed if usda is in NUTRITION_SOURCE)
USDA_FDC_API_KEY=

# Path to the TACO dataset (required when 'taco' is in NUTRITION_SOURCE).
# Accepts .csv or .xlsx. Drop the file under ./data (mounted into the container).
TACO_DATA_PATH=/data/taco.csv

# --- Model (optional — only used when PARSER_TIER > 0) ---
# Adapter for embeddings and LLM: ollama
MODEL_ADAPTER=ollama

# Ollama API base URL (must match the ollama service in docker-compose)
OLLAMA_URL=http://ollama:11434

# Embedding model (Tier 1 matcher)
EMBED_MODEL=nomic-embed-text

# LLM model (Tier 2 parser)
LLM_MODEL=llama3.1

# HTTP timeout for Ollama API calls
MODEL_TIMEOUT=30s

# Minimum cosine similarity for an embedding match to be accepted (0..1)
EMBED_MATCH_THRESHOLD=0.80

# Minimum cosine similarity to auto-write an embedding match as a food alias (0..1)
ALIAS_WRITE_BACK_THRESHOLD=0.92

# --- Notifications ---
# Notifier adapter: ntfy, gotify, webhook
NOTIFIER=ntfy

# ntfy server URL (self-hosted or ntfy.sh)
NTFY_URL=

# ntfy topic to publish to
NTFY_TOPIC=

# ntfy access token (optional — only if your ntfy server restricts publishing)
NTFY_TOKEN=

# Gotify server URL (optional — only used when NOTIFIER=gotify)
GOTIFY_URL=
# Gotify app token (optional — only used when NOTIFIER=gotify)
GOTIFY_TOKEN=

# --- Timezone ---
# IANA timezone for daily rollup boundaries and scheduler ticks.
# Overridable per-user once multi-user lands.
DEFAULT_TIMEZONE=America/Sao_Paulo

# --- Database ---
# Path to the SQLite database file
DB_PATH=/data/dietdaemon.db

# --- Auth ---
# Enable multi-user mode (requires tokens in api_tokens table)
MULTI_USER=false

# Static API bearer token for single-user mode (empty = no auth for localhost)
API_AUTH_TOKEN=

# --- Feature flags ---
# Enable push notifications for target-miss nudges
ENABLE_NOTIFICATIONS=true

# Enable the optional dashboard UI (backend must still boot headless without it)
ENABLE_DASHBOARD=false

# Enable speech-to-text processing for audio messages
ENABLE_STT=false

# Whisper.cpp HTTP server URL (required when ENABLE_STT=true)
WHISPER_URL=http://whisper:8080

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info
